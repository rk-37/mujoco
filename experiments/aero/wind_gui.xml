<mujoco model="wind_flag">
  <statistic extent="1.2" center="0 0 0.6"/>

  <visual>
    <global realtime="0.5"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <scale forcewidth="0.05" contactwidth="0.1" contactheight="0.05"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="64" height="64"/>
    <texture name="grid" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .15 .2"
             width="512" height="512" mark="cross" markrgb=".8 .8 .8"/>
    <material name="grid" texture="grid" texrepeat="2 2" reflectance="0.2"/>
  </asset>

  <!-- gusty wind along +x; air density + viscosity enable lift/drag -->
  <option density="1.225" viscosity="2.8e-5" wind="10 10 1" integrator="implicitfast" timestep="0.002"/>

  <worldbody>
    <light pos="0 -1 3" dir="0 1 -2" diffuse="1 1 1"/>
    <geom name="ground" type="plane" size="3 3 .1" material="grid" condim="3"/>

    <!-- fixed mast -->
    <geom name="mast" type="capsule" fromto="0 0 0 0 0 1.0" size="0.02" rgba=".5 .5 .5 1"/>

    <!-- plate tethered at the top of the mast by a ball joint: it swings and
         flutters in the wind but stays in frame -->
    <body name="flag" pos="0 0 1.0">
      <joint name="swing" type="ball" damping="0.002"/>
      <geom name="flag" type="ellipsoid" pos="0.2 0 0" size="0.2 0.15 0.002"
            mass="0.01" fluidshape="ellipsoid" rgba="0 .5 .8 1"/>
      <site name="flagcenter" pos="0.2 0 0"/>
    </body>
  </worldbody>

  <sensor>
    <!-- live readouts shown in simulate's sensor plot -->
    <accelerometer name="accel" site="flagcenter"/>
    <velocimeter   name="vel"   site="flagcenter"/>
    <framepos      name="pos"   objtype="site" objname="flagcenter"/>
  </sensor>
</mujoco>
