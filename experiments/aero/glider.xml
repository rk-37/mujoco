<mujoco model="glider">
  <statistic extent="6" center="3 0 1.5"/>

  <visual>
    <global realtime="0.4" azimuth="120" elevation="-10"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <map zfar="80"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="64" height="64"/>
    <texture name="grid" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .15 .2"
             width="512" height="512" mark="cross" markrgb=".8 .8 .8"/>
    <material name="grid" texture="grid" texrepeat="8 8" reflectance="0.2"/>
  </asset>

  <!-- still air (no wind); the glider's own motion creates the airflow -->
  <option density="1.225" viscosity="1.8e-5" gravity="0 0 -9.81"
          integrator="implicitfast" timestep="0.002"/>

  <worldbody>
    <light pos="2 -2 6" dir="0 0.3 -1" diffuse="1 1 1"/>
    <geom name="ground" type="plane" pos="20 0 0" size="40 10 .1" material="grid" condim="3"/>

    <!-- nose points in +x (direction of flight) -->
    <body name="glider" pos="0 0 3">
      <freejoint/>
      <!-- fuselage rod -->
      <geom name="fuse" type="capsule" fromto="0.45 0 0  -0.55 0 0" size="0.015"
            mass="0.05" rgba=".4 .4 .45 1"/>
      <!-- nose ballast at the FRONT (+x): puts CG ahead of aero centre => stable -->
      <geom name="nose" type="sphere" pos="0.45 0 0" size="0.03" mass="0.30"
            rgba=".7 .2 .2 1"/>
      <!-- main wing, +2 deg incidence. fluidcoef tuned for higher L/D:
           low blunt/slender drag, boosted Kutta lift -->
      <geom name="wing" type="ellipsoid" pos="0.20 0 0" euler="0 -2 0"
            size="0.12 0.7 0.008" mass="0.10" fluidshape="ellipsoid"
            fluidcoef="0.05 0.02 1.5 2.5 1.0"
            rgba=".85 .55 0 1"/>
      <!-- horizontal tailplane, aft (-x) -->
      <geom name="tail" type="ellipsoid" pos="-0.50 0 0"
            size="0.07 0.25 0.006" mass="0.03" fluidshape="ellipsoid"
            rgba=".2 .6 .85 1"/>
      <!-- vertical fin for yaw stability -->
      <geom name="fin" type="ellipsoid" pos="-0.50 0 0.08" euler="90 0 0"
            size="0.06 0.10 0.005" mass="0.02" fluidshape="ellipsoid"
            rgba=".2 .6 .85 1"/>
    </body>
  </worldbody>

  <keyframe>
    <!-- launch: 14 m/s forward (+x), level, at 3 m altitude -->
    <key name="launch" qpos="0 0 3  1 0 0 0" qvel="14 0 0  0 0 0"/>
  </keyframe>
</mujoco>
